{
  "name": "infer-cmd",
  "version": "0.1.3",
  "description": "When a shell command fails, type `infer` to get an LLM-powered fix for your last command.",
  "type": "module",
  "bin": {
    "infer": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node -e \"console.log('infer-cmd: run \\u0027infer setup\\u0027 to wire your shell (one line, 10 seconds)')\" || true",
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "llm",
    "ai",
    "shell",
    "fix",
    "command",
    "thefuck",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "smol-toml": "^1.3.1",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
